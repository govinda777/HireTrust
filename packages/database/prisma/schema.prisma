generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id            String   @id @default(uuid())
  type          String
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id")
  data          Json
  createdAt     DateTime @default(now())

  @@index([aggregateId])
  @@index([aggregateType])
}

model Agreement {
  id           String   @id
  subscriberId String
  providerId   String
  termsHash    String
  status       String   @default("PENDING")
  onChainHash  String?
  proofHash    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Offer {
  id          String   @id @default(uuid())
  providerId  String
  title       String
  description String
  price       Decimal
  createdAt   DateTime @default(now())
}

model Subscription {
  id             String         @id
  subscriberId   String
  agreementId    String
  planId         String
  intervalInDays Int
  price          Decimal
  status         String
  healthScore    Float          @default(100)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  cycles         BillingCycle[]
}

model BillingCycle {
  id             String       @id
  subscriptionId String
  cycleNumber    Int
  status         String
  dueDate        DateTime
  paymentDate    DateTime?
  proofHash      String?
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
}

model SlaPolicy {
  id              String      @id
  agreementId     String      @unique
  minUptime       Float
  maxResponseTime Float
  minSuccessRate  Float
  metrics         SlaMetric[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model SlaMetric {
  id          String    @id @default(uuid())
  slaPolicyId String
  cycleId     String
  type        String
  value       Float
  timestamp   DateTime  @default(now())
  slaPolicy   SlaPolicy @relation(fields: [slaPolicyId], references: [id])

  @@index([cycleId])
}
