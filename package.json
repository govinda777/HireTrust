{
  "name": "hiretrust-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:unit": "vitest run",
    "test:integration": "vitest run -c vitest.config.integration.ts",
    "test:blockchain": "cd packages/blockchain && npx hardhat test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "chai": "^6.2.2",
    "ethers": "^6.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "vitest run --passWithNoTests"
    ]
  }
}
